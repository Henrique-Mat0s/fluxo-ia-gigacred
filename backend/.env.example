DISPARO_MAX_INTERVALO_MS=90000   # 90s máximo
DISPARO_LIMITE_DIA=150           # máximo por dia/chip
DISPARO_LIMITE_BLOQUEIO_PCT=5    # se >5% bloqueio, pausa automaticamente
